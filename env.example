# =============================================================================
# SynthTrade - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to GitHub. It is already in .gitignore.

# --- Deriv API ---
# Get your App ID from: https://api.deriv.com/
# The default (1089) is the public demo app and works for most historical data.
DERIV_APP_ID=1089

# Get your API token from: https://app.deriv.com/account/api-token
# Scopes needed: Read, Trading information
# Leave blank for demo/public mode (limited features).
DERIV_API_TOKEN=

# --- Twelve Data API (optional, for live real market data) ---
# Free tier: 800 API calls/day. Sign up at: https://twelvedata.com/
# If left blank, the system falls back to yfinance for historical data only.
TWELVE_DATA_API_KEY=
